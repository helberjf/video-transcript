{
  "name": "modeloia-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/run-next-dev.mjs",
    "build": "prisma generate && next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "docx": "^9.6.1",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "next": "15.5.15",
    "next-auth": "^4.24.14",
    "react": "19.0.1",
    "react-dom": "19.0.1",
    "resend": "^6.12.4",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "dotenv": "^17.4.2",
    "postcss": "8.4.49",
    "prisma": "^7.8.0",
    "tailwindcss": "3.4.16",
    "tsx": "^4.22.4",
    "typescript": "5.7.2"
  }
}

APP_NAME=Local Media Transcript Studio
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Local: frontend em http://localhost:3000
# Vercel producao: adicione https://seu-projeto.vercel.app
# VPS/proxy reverso: ajuste APP_HOST para 0.0.0.0 se precisar expor o backend fora da maquina local
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Opcional: libera previews da Vercel sem cadastrar cada subdominio manualmente
# Exemplo: https://seu-projeto-git-main-usuario.vercel.app
CORS_ORIGIN_REGEX=

DATABASE_URL=sqlite:///./data/app.db
BACKEND_AUTH_SECRET=troque-por-um-segredo-compartilhado-com-a-vercel
BACKEND_AUTH_REQUIRED=false
STORAGE_DIR=../storage
UPLOADS_DIR=../storage/uploads
PROCESSED_DIR=../storage/processed
EXPORTS_DIR=../storage/exports
TEMP_DIR=../storage/temp

MAX_UPLOAD_MB=500
AUTO_CLEANUP_TEMP_FILES=true
DEFAULT_LANGUAGE=pt-BR
WHISPER_MODEL=medium

OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REPORT_MODEL=gpt-4.1-mini
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash
GEMINI_REPORT_MODEL=gemini-2.5-flash

PROVIDER_TIMEOUT_SECONDS=120
PROVIDER_RETRIES=2

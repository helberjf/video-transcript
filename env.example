# Configuração do Google Gemini AI
# Obtenha sua chave em: https://aistudio.google.com/
GEMINI_API_KEY=sua_chave_gemini_aqui

# Configuração do Servidor
PORT=5000
DEBUG=False

# Cookies para Instagram (opcional)
# Opção 1: Arquivo de cookies no formato Netscape
INSTAGRAM_COOKIES_FILE=/caminho/para/cookies.txt

# Opção 2: Extrair cookies do navegador
# Formato: browser:profile (ex: firefox:default, chrome:Profile1)
# INSTAGRAM_COOKIES_FROM_BROWSER=firefox:default

# Alternativas para yt-dlp (caso use outro nome de variável)
# YTDLP_COOKIES_FILE=/caminho/para/cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome:default

# ─── Credenciais de demonstração ─────────────────────────────────────────────
# Geradas pelo seed: cd frontend && npm run prisma:seed
# Use /acesso para fazer login com essas credenciais
#
# Admin:   admin@modeloia.com
DEMO_ADMIN_PASSWORD=Admin@2026
#
# Cliente: cliente@modeloia.com
DEMO_CLIENT_PASSWORD=Cliente@2026

# ─── Envio de email (recuperação de senha) ───────────────────────────────────
# Sem SMTP configurado, o link é logado no console em modo dev
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@gmail.com
# SMTP_PASS=sua_senha_de_app
# SMTP_FROM=noreply@modeloia.com

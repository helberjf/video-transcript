# URLs publicas do webapp na Vercel
NEXT_PUBLIC_APP_URL=https://SEU-PROJETO.vercel.app
NEXTAUTH_URL=https://SEU-PROJETO.vercel.app
NEXT_PUBLIC_API_BASE_URL=https://api.SEUDOMINIO.com/api
NEXT_PUBLIC_DESKTOP_MODE=0

# Supabase PostgreSQL
# DATABASE_URL: use a connection string com pooler/pgbouncer do Supabase.
# DIRECT_URL: use a connection string direta do Supabase para migracoes Prisma.
DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA_DO_BANCO@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:SENHA_DO_BANCO@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Auth.js / NextAuth
# Gere um segredo longo e use o mesmo valor em NEXTAUTH_SECRET e AUTH_SECRET.
NEXTAUTH_SECRET=COLE_UM_SEGREDO_LONGO_AQUI
AUTH_SECRET=COLE_O_MESMO_VALOR_DO_NEXTAUTH_SECRET_AQUI

# Token curto que o Next.js gera para o backend FastAPI.
# Configure o mesmo valor no backend em BACKEND_AUTH_SECRET.
BACKEND_AUTH_SECRET=COLE_UM_SEGREDO_LONGO_COMPARTILHADO_COM_FASTAPI

# Google OAuth
# Callback em producao: https://SEU-PROJETO.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=COLE_SEU_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=COLE_SEU_GOOGLE_CLIENT_SECRET

# Stripe Billing
# Webhook em producao: https://SEU-PROJETO.vercel.app/api/stripe/webhook
STRIPE_SECRET_KEY=sk_live_COLE_SUA_CHAVE
STRIPE_WEBHOOK_SECRET=whsec_COLE_SEU_WEBHOOK_SECRET
STRIPE_PRICE_PRO_MONTHLY=price_COLE_PRICE_PRO
STRIPE_PRICE_BUSINESS_MONTHLY=price_COLE_PRICE_BUSINESS

# Variaveis equivalentes para o backend FastAPI em producao.
# Se o backend ficar fora da Vercel, configure estas no ambiente dele tambem.
BACKEND_AUTH_REQUIRED=true
CORS_ORIGINS=https://SEU-PROJETO.vercel.app
